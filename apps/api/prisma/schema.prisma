// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String    @unique @db.VarChar(30)
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  avatarUrl          String?   @map("avatar_url")
  factionPreference  String    @default("auto") @map("faction_preference") @db.VarChar(20)
  countryCode        String?   @map("country_code") @db.Char(2)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt         DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz

  ratings            UserRating[]
  gamesAsWhite       Game[]         @relation("WhitePlayer")
  gamesAsBlack       Game[]         @relation("BlackPlayer")
  refreshTokens      RefreshToken[]

  @@map("users")
}

model UserRating {
  userId       String   @map("user_id") @db.Uuid
  category     String   @db.VarChar(20)  // bullet | blitz | rapid | classical
  rating       Int      @default(1200)
  peakRating   Int      @default(1200) @map("peak_rating")
  gamesPlayed  Int      @default(0) @map("games_played")
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, category])
  @@index([userId, category])
  @@map("user_ratings")
}

model Game {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whiteUserId         String?   @map("white_user_id") @db.Uuid
  blackUserId         String?   @map("black_user_id") @db.Uuid
  mode                String    @db.VarChar(20)   // online | local | ai
  timeControlBaseSec  Int       @map("time_control_base_sec")
  timeControlIncSec   Int       @default(0) @map("time_control_inc_sec")
  category            String    @db.VarChar(20)   // bullet | blitz | rapid | classical
  status              String    @default("waiting") @db.VarChar(20)  // waiting | active | ended
  result              String?   @db.VarChar(10)   // 1-0 | 0-1 | 1/2-1/2
  endReason           String?   @map("end_reason") @db.VarChar(30)
  finalFen            String?   @map("final_fen")
  pgn                 String?
  whiteEloAfter       Int?      @map("white_elo_after")
  blackEloAfter       Int?      @map("black_elo_after")
  whiteEloDelta       Int?      @map("white_elo_delta")
  blackEloDelta       Int?      @map("black_elo_delta")
  startedAt           DateTime? @map("started_at") @db.Timestamptz
  endedAt             DateTime? @map("ended_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  whitePlayer         User?     @relation("WhitePlayer", fields: [whiteUserId], references: [id])
  blackPlayer         User?     @relation("BlackPlayer", fields: [blackUserId], references: [id])
  moves               Move[]

  @@index([whiteUserId])
  @@index([blackUserId])
  @@index([status, category])
  @@map("games")
}

model Move {
  id            BigInt   @id @default(autoincrement())
  gameId        String   @map("game_id") @db.Uuid
  moveNumber    Int      @map("move_number") @db.SmallInt
  color         String   @db.Char(1)   // w | b
  san           String   @db.VarChar(10)
  fromSq        String   @map("from_sq") @db.Char(2)
  toSq          String   @map("to_sq") @db.Char(2)
  promotion     String?  @db.Char(1)
  fenAfter      String   @map("fen_after")
  whiteClockMs  Int      @map("white_clock_ms")
  blackClockMs  Int      @map("black_clock_ms")
  playedAt      DateTime @default(now()) @map("played_at") @db.Timestamptz

  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, moveNumber])
  @@map("moves")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
